{
  "name": "navigation-agent-mcp-monorepo",
  "private": true,
  "packageManager": "npm@10",
  "workspaces": [
    "packages/mcp-server",
    "packages/contract-tests"
  ],
  "scripts": {
    "mcp-server:dev": "npm --workspace @navigation-agent/mcp-server run dev",
    "mcp-server:build": "npm --workspace @navigation-agent/mcp-server run build",
    "mcp-server:test": "npm --workspace @navigation-agent/mcp-server run test",
    "mcp-server:check": "npm --workspace @navigation-agent/mcp-server run check",
    "contract-tests": "npm --workspace @navigation-agent/contract-tests run test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "version": "0.1.3"
}
