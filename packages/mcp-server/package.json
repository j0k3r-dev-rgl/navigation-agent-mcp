{
  "name": "@navigation-agent/mcp-server",
  "version": "0.1.4",
  "description": "MCP server for AI-assisted code navigation — find symbols, trace callers, list endpoints and more.",
  "type": "module",
  "bin": {
    "navigation-mcp": "./dist/bin/navigation-mcp.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node --experimental-strip-types ./src/bin/navigation-mcp.ts --transport stdio",
    "build": "tsc -p tsconfig.build.json && node ../../scripts/add-shebang.mjs dist/bin/navigation-mcp.js",
    "test": "node --experimental-strip-types --test ./test/**/*.spec.ts",
    "check": "tsc --noEmit"
  },
  "optionalDependencies": {
    "@navigation-agent/mcp-server-linux-x64": "0.1.4",
    "@navigation-agent/mcp-server-linux-arm64": "0.1.4",
    "@navigation-agent/mcp-server-darwin-x64": "0.1.4",
    "@navigation-agent/mcp-server-darwin-arm64": "0.1.4",
    "@navigation-agent/mcp-server-win32-x64": "0.1.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/j0k3r-dev-rgl/navigation-agent-mcp.git"
  },
  "keywords": [
    "mcp",
    "ai",
    "code-navigation",
    "typescript",
    "rust"
  ]
}
