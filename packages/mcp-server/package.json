{
  "name": "@navigation-agent/mcp-server",
  "version": "0.8.1",
  "description": "Workspace-only MCP server for structural code discovery, symbol lookup, impact analysis, and downstream flow tracing before reading or modifying code.",
  "type": "module",
  "bin": {
    "navigation-mcp": "dist/bin/navigation-mcp.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "npx tsx ./src/bin/navigation-mcp.ts --transport stdio",
    "build": "tsc -p tsconfig.build.json && node ../../scripts/add-shebang.mjs dist/bin/navigation-mcp.js",
    "test": "npx tsx --test ./test/**/*.spec.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "optionalDependencies": {
    "@navigation-agent/mcp-server-linux-x64": "0.8.1",
    "@navigation-agent/mcp-server-linux-arm64": "0.8.1",
    "@navigation-agent/mcp-server-darwin-x64": "0.8.1",
    "@navigation-agent/mcp-server-darwin-arm64": "0.8.1",
    "@navigation-agent/mcp-server-win32-x64": "0.8.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j0k3r-dev-rgl/navigation-agent-mcp.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/j0k3r-dev-rgl/navigation-agent-mcp#readme",
  "bugs": {
    "url": "https://github.com/j0k3r-dev-rgl/navigation-agent-mcp/issues"
  },
  "keywords": [
    "mcp",
    "ai",
    "code-navigation",
    "impact-analysis",
    "call-graph",
    "typescript",
    "rust"
  ]
}
